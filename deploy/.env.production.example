# LUT Web production environment template
# Use placeholders only. Do not commit a real .env, APP_KEY, SMTP password, PayPal secret, or administrator credentials.

APP_NAME="LUT Web"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_ALLOWED_HOSTS=example.com,www.example.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lutweb
DB_USERNAME=lutweb
DB_PASSWORD=

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis

FILESYSTEM_DISK=local
LUT_TESTER_FFMPEG_BINARY=/www/server/ffmpeg/ffmpeg-6.1/ffmpeg
CUSTOM_LUT_FFMPEG_BINARY=/www/server/ffmpeg/ffmpeg-6.1/ffmpeg
STOREFRONT_MEDIA_ENABLED=true
STOREFRONT_MEDIA_PRIVATE_DISK=private
STOREFRONT_MEDIA_PUBLIC_DISK=public
STOREFRONT_MEDIA_QUEUE=images
STOREFRONT_MEDIA_JPEG_QUALITY=84
STOREFRONT_MEDIA_WEBP_QUALITY=82
STOREFRONT_EXAMPLE_WATERMARK=true
STOREFRONT_PRODUCT_MEDIA_WATERMARK=false
STOREFRONT_MEDIA_MAX_UPLOAD_MB=30

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@example.com
MAIL_FROM_NAME="LUT Web"

LEGAL_TERMS_VERSION=draft-1
LEGAL_PRIVACY_VERSION=draft-1
LEGAL_TERMS_OF_SALE_VERSION=draft-1
LEGAL_LICENSE_VERSION=draft-1
LEGAL_REFUND_POLICY_VERSION=draft-1
LEGAL_DIGITAL_DELIVERY_CONSENT_VERSION=draft-1

PAYPAL_ENABLED=false
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MERCHANT_ID=
PAYPAL_PAYEE_EMAIL=
PAYPAL_BRAND_NAME="LUT Web"
PAYPAL_CONNECT_TIMEOUT=5
PAYPAL_TIMEOUT=20
PAYPAL_WEBHOOK_QUEUE=payments
PAYPAL_PAYMENT_QUEUE=payments
PAYPAL_WEBHOOK_PAYLOAD_RETENTION_DAYS=7

CHECKOUT_ENABLED=false
CHECKOUT_SELLER_COUNTRY_CODE=
CHECKOUT_TAX_READY=false
CHECKOUT_LIVE_PAYMENTS_ALLOWED=false
CHECKOUT_PENDING_ORDER_EXPIRES_MINUTES=30
CHECKOUT_ATTEMPTS_PER_MINUTE=10
CHECKOUT_ATTEMPTS_PER_HOUR=60
CHECKOUT_CAPTURE_ATTEMPTS_PER_MINUTE=10
CHECKOUT_FREE_CLAIMS_PER_MINUTE=5
CHECKOUT_DOWNLOADS_PER_TEN_MINUTES=10

SEO_ENABLED=true
SEO_INDEXING_ENABLED=false
SEO_SITE_NAME="LUT Web"
SEO_DEFAULT_TITLE="Professional LUTs for Photographers and Creators"
SEO_DEFAULT_DESCRIPTION="Try professional LUTs on your photos, create custom looks, and securely download your purchases."
SEO_CANONICAL_URL=https://example.com
SEO_DEFAULT_OG_IMAGE=

CUSTOM_LUT_COMMERCE_ENABLED=false

SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true
CSP_REPORT_ONLY=true
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false
SECURITY_REQUIRE_HEARTBEATS_IN_PRODUCTION=true
