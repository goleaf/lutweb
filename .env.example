APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

LEGAL_TERMS_VERSION=draft-1
LEGAL_PRIVACY_VERSION=draft-1

LUT_TESTER_ENABLED=true
LUT_TESTER_PRIVATE_DISK=private
LUT_TESTER_FFMPEG_BINARY=ffmpeg
LUT_TESTER_FFMPEG_TIMEOUT=45
LUT_TESTER_PROCESS_IDLE_TIMEOUT=20
LUT_TESTER_QUEUE=images
LUT_TESTER_EXPIRES_MINUTES=60
LUT_TESTER_MAX_UPLOAD_MB=20
LUT_TESTER_MAX_PIXELS=50000000
LUT_TESTER_MAX_INPUT_EDGE=12000
LUT_TESTER_MIN_WIDTH=320
LUT_TESTER_MIN_HEIGHT=320
LUT_TESTER_PREVIEW_MAX_EDGE=1920
LUT_TESTER_PREVIEW_QUALITY=82
LUT_TESTER_MAX_ACTIVE_TESTS_PER_USER=3
LUT_TESTER_UPLOADS_PER_MINUTE=5
LUT_TESTER_UPLOADS_PER_DAY=30
LUT_TESTER_WATERMARK_TEXT="LUT WEB PREVIEW"
LUT_TESTER_WATERMARK_OPACITY=0.34
LUT_TESTER_WATERMARK_PATTERN_OPACITY=0.16
LUT_TESTER_WATERMARK_SPACING=360
LUT_TESTER_TRANSPARENCY_BACKGROUND="#ffffff"
LUT_TESTER_MAX_CUBE_SIZE_BYTES=20971520
LUT_TESTER_MAX_CUBE_LINE_LENGTH=8192
LUT_TESTER_MAX_CUBE_ABSOLUTE_CHANNEL_VALUE=64
LUT_TESTER_INTERPOLATION=tetrahedral
IMAGE_DRIVER=gd
