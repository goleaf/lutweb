server {
    listen 80;
    server_name example.com www.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name example.com www.example.com;

    root /var/www/lutweb-placeholder/public;
    index index.php;

    client_max_body_size 32m;

    ssl_certificate /path/to/fullchain.pem;
    ssl_certificate_key /path/to/privkey.pem;

    location ~ /\. {
        deny all;
    }

    location ~* (^|/)\.env {
        deny all;
    }

    location ^~ /storage/app/private/ {
        deny all;
    }

    location ~* ^/(storage|uploads)/.*\.php$ {
        deny all;
    }

    location ~* ^/storage/storefront/.+\.(?:jpg|jpeg|webp|png)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    location ~* \.(?:css|js|mjs|woff2?|ico|svg)$ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        fastcgi_pass unix:/run/php/php-fpm-placeholder.sock;
        fastcgi_read_timeout 120;
    }
}
