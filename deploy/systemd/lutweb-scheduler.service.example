[Unit]
Description=LUT Web scheduler
After=network.target

[Service]
Type=simple
User=www-data-placeholder
Group=www-data-placeholder
WorkingDirectory=/var/www/lutweb-placeholder
ExecStart=/usr/bin/php artisan schedule:work
ExecStop=/bin/kill -TERM $MAINPID
Restart=on-failure
RestartSec=5
TimeoutStopSec=90

[Install]
WantedBy=multi-user.target
